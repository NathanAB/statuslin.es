# Template for your env files (all gitignored). Copy to .env.local for local development:
#   .env.local      — local dev; the ONLY env file the running app reads locally (Bun auto-loads it).
#   .env.staging    — values you push to Fly staging secrets (a server never reads this file).
#   .env.production — values you push to Fly prod secrets (a server never reads this file).
# The two values below are pre-filled with working local-dev defaults — leave them as-is unless you
# changed the Postgres port or want a different dev URL (the dev server's port is derived from
# BETTER_AUTH_URL). Fill in BETTER_AUTH_SECRET and the GitHub OAuth creds (see README §2).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/statuslines
BETTER_AUTH_URL=http://localhost:3100
BETTER_AUTH_SECRET=        # openssl rand -base64 32
GITHUB_CLIENT_ID=          # from your dev GitHub OAuth app (see README §2)
GITHUB_CLIENT_SECRET=
E2B_API_KEY=               # optional locally — without it, submitted scripts use a fake runner
# PostHog analytics — set ONLY in .env.production. Read on the server at runtime and handed to the
# page, so leaving it unset keeps analytics OFF in local dev and staging (one shared project). The
# project token is a public, write-only key. POSTHOG_HOST is optional (defaults to us.i.posthog.com).
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://us.i.posthog.com

# Load testing only, and OPTIONAL — leave unset. scripts/loadtest/capture.ts derives the unpooled
# URL from DATABASE_URL by stripping `-pooler` from the host (so pg_stat_activity reads the real
# backends, not the pooler's view). Set this only to override that on a non-Neon host.
# DIRECT_DATABASE_URL=
