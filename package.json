{
  "name": "statuslines",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "start": "bun run .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "format:unsafe": "biome check --write --unsafe .",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:e2b": "RUN_E2B=1 bun --bun vitest run test/render/e2b.integration.test.ts test/render/e2b-network.integration.test.ts",
    "check": "bun run format && bun run check:ci",
    "check:ci": "bun run typecheck && bun run lint && bun run check:frontend && bun run check:boundaries && bun --bun run test",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "check:boundaries": "depcruise src --config .dependency-cruiser.cjs",
    "check:frontend": "bun run scripts/check-frontend.ts",
    "smoke": "bun run scripts/smoke.ts",
    "deploy:staging": "fly deploy --config fly.staging.toml",
    "deploy:prod": "bun run scripts/deploy-prod.ts",
    "render": "bun run scripts/render.ts",
    "rerender:previews": "bun run scripts/rerender-previews.ts",
    "worker": "bun run scripts/worker.ts",
    "build:e2b-template": "bun run scripts/build-e2b-template.ts",
    "build:font": "bun run scripts/build-font-subset.ts",
    "seed:gallery": "bun run scripts/seed-gallery.ts",
    "seed:community": "bun run scripts/run-seed-community.ts",
    "generate:content": "bun run scripts/generate-content.ts",
    "profile:bench": "bun run scripts/profiling/bench-phases.ts",
    "profile:server": "bun run scripts/profiling/profile-server.ts",
    "dev:login": "bun run scripts/dev-login.ts",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint && bun run typecheck",
    "pre-push": "bun run check:ci"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.11",
    "@number-flow/react": "0.6.0",
    "@posthog/react": "1.10.2",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-router": "1.170.9",
    "@tanstack/react-start": "1.168.16",
    "anser": "2.3.5",
    "better-auth": "1.6.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "e2b": "2.27.0",
    "lucide-react": "1.17.0",
    "postgres": "3.4.9",
    "posthog-node": "5.38.0",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "satori": "0.26.0",
    "shiki": "4.2.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tldts": "7.4.2",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@electric-sql/pglite": "0.4.6",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "dependency-cruiser": "17.4.3",
    "drizzle-kit": "0.31.10",
    "jsdom": "29.1.1",
    "nitro": "3.0.260522-beta",
    "simple-git-hooks": "2.13.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.7",
    "vitest-axe": "0.1.0"
  }
}
